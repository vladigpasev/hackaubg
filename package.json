{
  "name": "hackaubg",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@8.7.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "concurrently -c auto \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:frontend": "pnpm --filter frontend dev -- --host 0.0.0.0",
    "dev:backend": "pnpm --filter backend dev",
    "dev:infra": "docker compose -f infra/docker-compose.yml up -d",
    "dev:infra:down": "docker compose -f infra/docker-compose.yml down",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm --filter backend test:ci",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.2"
  }
}
